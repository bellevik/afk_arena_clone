; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Shardfall Legends"
config/description="An original mobile-first idle hero battler prototype built phase by phase."
run/main_scene="res://project/scenes/boot/boot.tscn"
config/features=PackedStringArray("4.3")
boot_splash/show_image=false

[autoload]

AppState="*res://project/scripts/core/app_state.gd"
GameData="*res://project/scripts/data/game_data.gd"
ProfileState="*res://project/scripts/core/profile_state.gd"
FormationState="*res://project/scripts/core/formation_state.gd"
CampaignState="*res://project/scripts/core/campaign_state.gd"
RewardState="*res://project/scripts/core/reward_state.gd"
SummonState="*res://project/scripts/core/summon_state.gd"
QuestState="*res://project/scripts/core/quest_state.gd"
EventState="*res://project/scripts/core/event_state.gd"
SettingsState="*res://project/scripts/core/settings_state.gd"
InventoryState="*res://project/scripts/core/inventory_state.gd"
SaveState="*res://project/scripts/save/save_state.gd"
SceneRouter="*res://project/scripts/core/scene_router.gd"
ThemeManager="*res://project/scripts/ui/theme_manager.gd"
DebugTools="*res://project/scripts/debug/debug_tools.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="mobile"
